# Keep the build context small and avoid copying host-only / wrong-platform artifacts into
# the image (notably the host .venv, which would clobber the container venv).
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Tooling caches
.pytest_cache/
.ruff_cache/
.ty_cache/
.mypy_cache/

# VCS / CI / editors
.git/
.github/
.idea/
.vscode/
.DS_Store

# Local secrets / env and signal-cli state
.env
.env.*
signal-cli-data/
*.d

# Docs / meta not needed at runtime
.claude/
