# --- Signal (signal-cli daemon) ---
SIGNAL_ACCOUNT=+15551234567
SIGNAL_HTTP_URL=http://127.0.0.1:8080

# --- BT Servant worker (the "brain") ---
ENGINE_BASE_URL=https://api.btservant.ai
ENGINE_ORG=unfoldingWord
ENGINE_API_KEY=your_engine_api_key

# Public URL of THIS gateway; the worker calls back {GATEWAY_PUBLIC_URL}/progress-callback
GATEWAY_PUBLIC_URL=https://your-signal-gateway.fly.dev

# --- Behavior ---
CHUNK_SIZE=1500
MESSAGE_AGE_CUTOFF_SECONDS=3600

# --- Groups (optional) ---
# Comma-separated allowed group member ids, or * for all. Empty = groups disabled.
SIGNAL_GROUP_ALLOWED_USERS=
SIGNAL_REQUIRE_MENTION=true
